{
	"name": "coedula",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --check .",
		"format:fix": "prettier --write .",
		"db:setup": "bash database/dev/setup.sh setup",
		"db:up": "pnpm run db:setup",
		"db:down": "tsx database/dev/migrate.ts reset",
		"db:status": "bash database/dev/setup.sh status",
		"db:reset": "bash database/dev/setup.sh reset",
		"db:rebuild": "bash database/dev/setup.sh reset --yes",
		"db:init": "tsx database/dev/migrate.ts init",
		"db:migrate": "tsx database/dev/migrate.ts migrate",
		"db:rollback": "tsx database/dev/migrate.ts rollback",
		"db:check": "tsx database/dev/migrate.ts check",
		"db:create": "tsx database/dev/migrate.ts create",
		"db:generate": "kysely-codegen --config-file kysely.config.ts"
	},
	"packageManager": "pnpm@10.32.1",
	"dependencies": {
		"@floating-ui/dom": "^1.7.6",
		"@lucide/svelte": "^0.577.0",
		"bcryptjs": "^3.0.3",
		"cookie": "^1.1.1",
		"jsonwebtoken": "^9.0.3",
		"kysely": "^0.28.13",
		"lucide-svelte": "^0.577.0",
		"pdf-lib": "^1.17.1",
		"pg": "^8.20.0",
		"qrcode": "^1.5.4",
		"sharp": "^0.34.5"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.5.0",
		"@types/pg": "^8.18.0",
		"@types/qrcode": "^1.5.6",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"kysely-codegen": "^0.20.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.5",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1",
		"vite": "^8.0.0"
	}
}
